class sin_sampler_dist(rv_continuous):

    def _pdf(self, theta):
        return 0.5*np.sin(theta)

sin_sampler = sin_sampler_dist(a=0, b=np.pi)

class circuit_constructor:
    
    def __init__(self, **kwargs):
        
        self.coeff = kwargs['coeff_vector']
        self.ladder_coupling_dict = kwargs["ladder_coupling_dict"]
     
    
        
        
        
        self.connectivity_list = kwargs["connectivity_list"]
        
        self.clean_qubit = kwargs["clean_qubit_index"]
        self.probe_qubit = kwargs["probe_qubit_index"]
        self.no_layers = kwargs["no_layers"]
        self.time_list = kwargs["Evol_time_list"]
        self.time_step = kwargs["time_step_length"]
        self.kappa = kwargs["kappa"]
        self.int_type = kwargs["int_type"]
      
        
        #self.session_driver()
    
       
    def Trotter_circuit_new(self):
        
        for top_list_index, top_list in enumerate(self.connectivity_list):
                
            for q in top_list: 
                if q not in list(self.ladder_coupling_dict.keys()):
                    #print("normal", q, self.coeff[0], self.coeff[1], self.coeff[2])
                    theta_x = 0.25*(self.coeff[0]*self.time_step)
                    theta_y = 0.25*(self.coeff[1]*self.time_step)
                    theta_z = 0.25*(self.coeff[2]*self.time_step)

                    self.circuit.cx(q[0], q[1])
                    self.circuit.rx(2*theta_x, q[0])
                    # self.circuit.h(q[1])
                    self.circuit.rz(2*theta_z, q[1])
                    # self.circuit.h(q[1])
    
                    self.circuit.h(q[0])
                    self.circuit.cx(q[0], q[1])
                    self.circuit.rz(-np.pi/2, q[0])
                    self.circuit.h(q[0])
                    # self.circuit.h(q[1])
                    self.circuit.rz(-2*theta_y, q[1])
                    # self.circuit.h(q[1])
    
                    self.circuit.cx(q[0], q[1])
                    self.circuit.rx(np.pi/2, q[0])
                    self.circuit.rx(-np.pi/2, q[1])
                
                else:
                   # print("ladder", q, self.ladder_coupling_dict[q][0], self.ladder_coupling_dict[q][1], self.ladder_coupling_dict[q][2])

                    theta_x = 0.25*(self.ladder_coupling_dict[q][0]*self.time_step)*self.int_type[0][0]
                    theta_y = 0.25*(self.ladder_coupling_dict[q][1]*self.time_step)*self.int_type[0][1]
                    theta_z = 0.25*(self.ladder_coupling_dict[q][2]*self.time_step)*self.int_type[0][2]

                    # print(theta_x,theta_y,theta_z)

                    self.circuit.cx(q[0], q[1])
                    self.circuit.rx(2*theta_x, q[0])
                    # self.circuit.h(q[1])
                    self.circuit.rz(2*theta_z, q[1])
                    # self.circuit.h(q[1])
    
                    self.circuit.h(q[0])
                    self.circuit.cx(q[0], q[1])
                    self.circuit.rz(-np.pi/2, q[0])
                    self.circuit.h(q[0])
                    # self.circuit.h(q[1])
                    self.circuit.rz(-2*theta_y, q[1])
                    # self.circuit.h(q[1])
    
                    self.circuit.cx(q[0], q[1])
                    self.circuit.rx(np.pi/2, q[0])
                    self.circuit.rx(-np.pi/2, q[1])
                    
  
        return self
    
    
    def random_circuit_constructor(self):
    
    # generic brickwork ansatz of random gates, excluding clean_q
        for _ in range(self.no_layers):
            for top in self.connectivity_list:
                for t in top:
                    if t[0] != self.clean_qubit and t[1] != self.clean_qubit:
                    
                        self.circuit.h(t[0])
                        self.circuit.rx(uniform(-np.pi, np.pi), t[0])
                        self.circuit.h(t[0])
                        self.circuit.ry(float(sin_sampler.rvs(size=1)), t[0])
                        self.circuit.h(t[0])
                        self.circuit.rx(uniform(-np.pi, np.pi), t[0])
                        self.circuit.h(t[0])

                        self.circuit.h(t[1])
                        self.circuit.rx(uniform(-np.pi, np.pi), t[1])
                        self.circuit.h(t[1])
                        self.circuit.ry(float(sin_sampler.rvs(size=1)), t[1])
                        self.circuit.h(t[1])
                        self.circuit.rx(uniform(-np.pi, np.pi), t[1])
                        self.circuit.h(t[1])

                   
                        self.circuit.cz(t[0], t[1])  
        return self


    def full_circuit_constructor(self, trotter_steps):
        
        self.circuit = QuantumCircuit(29, 1)
    
        # apply quasi haar random initial state, leaving qubit 'clean_q' in zero state
        self.random_circuit_constructor()

        self.circuit.barrier()
    
        # trotter evolution under XXZ Heisenberg hamiltonian
        for _ in range(trotter_steps):
            self.Trotter_circuit_new()
        
        # self.circuit.measure([self.probe_qubit], [0])

        return self


    def session_driver(self):
      
                
        backend=Aer.get_backend('statevector_simulator')
        backend.set_options(device="GPU")

        circs = [self.full_circuit_constructor(int(time/self.time_step)).circuit for time in tqdm(self.time_list)]
        Z_13 = SparsePauliOp.from_sparse_list([("Z", [13], 1)], 29)

        job = backend.run(circs)
        self.result = job.result()
        C00 = [self.result.results[k].data.statevector.expectation_value(Z_13) for k in range(len(circs))]

        with open("29q_"+str(self.time_step)+str(self.int_type[1])+str(self.kappa)+".pkl", 'wb') as f:
            pickle.dump(C00, f)

        print(str(self.time_step) +"_" + str(self.int_type[1]) + "_" + str(self.kappa))


        return self

